{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena.git",
        "serena",
        "start-mcp-server",
        "--project",
        "C:/Users/Haniefu Fuda/Downloads/hanjeli-smartfarm"
      ],
      "env": {
        "UV_USE_SYSTEM_GIT": "1"
      }
    },
    "browsermcp": {
      "command": "npx",
      "args": [
        "-y",
        "@browsermcp/mcp@latest"
      ]
    },
    "magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@21st-dev/magic@latest"
      ],
      "env": {
        "API_KEY": "21st_sk_af991c5383ea06771266b64b0c78761b466707061277b7b5ee6f54904f767098"
      }
    }
  }
}