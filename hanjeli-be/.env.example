# Hanjeli Smart Farm - Backend Environment
# Copy this file to .env and adjust the values for your machine.

# App
NODE_ENV=development
PORT=3000
# Public origin of THIS backend, used to build absolute URLs (e.g. uploaded avatars
# served at /uploads/*). In production set to your API origin, e.g. https://api.yourdomain.com
PUBLIC_BACKEND_URL=http://localhost:3000

# PostgreSQL + TimescaleDB
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=hanjeli_admin
DB_PASSWORD=hanjeli_password_super_aman
DB_NAME=hanjeli_smartfarm_db

# Database Pool
DB_POOL_MAX=20

# Database Options
DB_MIGRATIONS_RUN=false
DB_LOGGING=true

# Security
ENCRYPTION_KEY=generate-a-strong-random-string-here
BCRYPT_ROUNDS=12

# Admin Seeding — dilakukan via CLI, BUKAN dari env file
# Jalankan: npm run db:setup
# Lihat opsi lengkap: npm run db:setup -- --help

# Auth / JWT
JWT_ACCESS_SECRET=generate-a-strong-access-token-secret
JWT_REFRESH_SECRET=generate-a-strong-refresh-token-secret
JWT_CHALLENGE_SECRET=generate-a-strong-2fa-challenge-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_CHALLENGE_EXPIRES_IN=10m
TWO_FACTOR_ENCRYPTION_SECRET=generate-a-strong-2fa-encryption-secret
AUTH_TOKEN_HASH_SECRET=generate-a-strong-auth-token-hash-secret
AUTH_EMAIL_TOKEN_EXPIRES_IN=24h
AUTH_RESET_TOKEN_EXPIRES_IN=30m

# Google OAuth - localhost self-run mode
# Use this when each tester runs backend and frontend on their own machine.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v3/auth/google/callback
FRONTEND_URL=http://localhost:3001
FRONTEND_ORIGINS=http://localhost:3001
FRONTEND_AUTH_CALLBACK_URL=http://localhost:3001/auth/callback

# Google OAuth - public testing via tunnel
# Use these values instead of the localhost values above when testers access
# your local machine through public URLs from ngrok, Cloudflare Tunnel, etc.
# GOOGLE_CALLBACK_URL=https://your-api-tunnel.example.com/api/v3/auth/google/callback
# FRONTEND_URL=https://your-web-tunnel.example.com
# FRONTEND_ORIGINS=https://your-web-tunnel.example.com
# FRONTEND_AUTH_CALLBACK_URL=https://your-web-tunnel.example.com/auth/callback

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Hanjeli SmartFarm <no-reply@example.com>"

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=
REDIS_KEY_PREFIX=hanjeli

# Weather / Open-Meteo
WEATHER_LATITUDE=-7.19
WEATHER_LONGITUDE=106.61
WEATHER_CACHE_TTL_SECONDS=900
# Use "redis" to enable Redis-backed weather cache; use "memory" for local fallback.
WEATHER_CACHE_DRIVER=memory

# MQTT / ESP32 IoT
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=hanjeli-api-dev
MQTT_CONNECT_TIMEOUT_MS=30000
MQTT_RECONNECT_INITIAL_MS=1000
MQTT_RECONNECT_MAX_MS=30000
MQTT_IRRIGATION_ACK_TIMEOUT_MS=10000
